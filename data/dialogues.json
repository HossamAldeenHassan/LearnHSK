[
  { "id": 1001, "lesson": 1, "dialogue_id": 1, "line_index": 1, "speaker": "A", "hanzi": "你好！", "pinyin": "nǐ hǎo!", "arabic": "مرحباً!", "type": "dialogue" },
  { "id": 1002, "lesson": 1, "dialogue_id": 1, "line_index": 2, "speaker": "B", "hanzi": "你好！", "pinyin": "nǐ hǎo!", "arabic": "مرحباً!", "type": "dialogue" },
  { "id": 1003, "lesson": 1, "dialogue_id": 2, "line_index": 1, "speaker": "A", "hanzi": "您好！", "pinyin": "nín hǎo!", "arabic": "مرحباً بحضرتك!", "type": "dialogue" },
  { "id": 1004, "lesson": 1, "dialogue_id": 2, "line_index": 2, "speaker": "B", "hanzi": "你们好！", "pinyin": "nǐ men hǎo!", "arabic": "مرحباً بكم!", "type": "dialogue" },
  { "id": 1005, "lesson": 1, "dialogue_id": 3, "line_index": 1, "speaker": "A", "hanzi": "对不起！", "pinyin": "duì bu qǐ!", "arabic": "آسف!", "type": "dialogue" },
  { "id": 1006, "lesson": 1, "dialogue_id": 3, "line_index": 2, "speaker": "B", "hanzi": "没关系！", "pinyin": "méi guān xi!", "arabic": "لا بأس!", "type": "dialogue" },
  { "id": 1007, "lesson": 2, "dialogue_id": 1, "line_index": 1, "speaker": "A", "hanzi": "谢谢！", "pinyin": "xiè xie!", "arabic": "شكراً!", "type": "dialogue" },
  { "id": 1008, "lesson": 2, "dialogue_id": 1, "line_index": 2, "speaker": "B", "hanzi": "不谢！", "pinyin": "bú xiè!", "arabic": "عفواً!", "type": "dialogue" },
  { "id": 1009, "lesson": 2, "dialogue_id": 2, "line_index": 1, "speaker": "A", "hanzi": "谢谢你！", "pinyin": "xiè xie nǐ!", "arabic": "شكراً لك!", "type": "dialogue" },
  { "id": 1010, "lesson": 2, "dialogue_id": 2, "line_index": 2, "speaker": "B", "hanzi": "不客气！", "pinyin": "bú kè qì!", "arabic": "عفواً!", "type": "dialogue" },
  { "id": 1011, "lesson": 2, "dialogue_id": 3, "line_index": 1, "speaker": "A", "hanzi": "再见！", "pinyin": "zài jiàn!", "arabic": "إلى اللقاء!", "type": "dialogue" },
  { "id": 1012, "lesson": 2, "dialogue_id": 3, "line_index": 2, "speaker": "B", "hanzi": "再见！", "pinyin": "zài jiàn!", "arabic": "إلى اللقاء!", "type": "dialogue" },
  { "id": 1013, "lesson": 3, "dialogue_id": 1, "line_index": 1, "speaker": "A", "hanzi": "你叫什么名字？", "pinyin": "nǐ jiào shén me míng zi?", "arabic": "ما اسمك؟", "type": "dialogue" },
  { "id": 1014, "lesson": 3, "dialogue_id": 1, "line_index": 2, "speaker": "B", "hanzi": "我叫李月。", "pinyin": "wǒ jiào lǐ yuè.", "arabic": "اسمي لي يوي.", "type": "dialogue" },
  { "id": 1015, "lesson": 3, "dialogue_id": 2, "line_index": 1, "speaker": "A", "hanzi": "你是老师吗？", "pinyin": "nǐ shì lǎo shī ma?", "arabic": "هل أنت معلم؟", "type": "dialogue" },
  { "id": 1016, "lesson": 3, "dialogue_id": 2, "line_index": 2, "speaker": "B", "hanzi": "我不是老师，我是学生。", "pinyin": "wǒ bú shì lǎo shī, wǒ shì xué shēng.", "arabic": "لست معلماً، أنا طالب.", "type": "dialogue" },
  { "id": 1017, "lesson": 3, "dialogue_id": 3, "line_index": 1, "speaker": "A", "hanzi": "你是中国人吗？", "pinyin": "nǐ shì zhōng guó rén ma?", "arabic": "هل أنت صيني؟", "type": "dialogue" },
  { "id": 1018, "lesson": 3, "dialogue_id": 3, "line_index": 2, "speaker": "B", "hanzi": "我不是中国人，我是美国人。", "pinyin": "wǒ bú shì zhōng guó rén, wǒ shì měi guó rén.", "arabic": "لست صينياً، أنا أمريكي.", "type": "dialogue" },
  { "id": 1019, "lesson": 4, "dialogue_id": 1, "line_index": 1, "speaker": "A", "hanzi": "她是谁？", "pinyin": "tā shì shéi?", "arabic": "من هي؟", "type": "dialogue" },
  { "id": 1020, "lesson": 4, "dialogue_id": 1, "line_index": 2, "speaker": "B", "hanzi": "她是我的汉语老师，她叫李月。", "pinyin": "tā shì wǒ de hàn yǔ lǎo shī, tā jiào lǐ yuè.", "arabic": "هي معلمتي للغة الصينية، اسمها لي يوي.", "type": "dialogue" },
  { "id": 1021, "lesson": 4, "dialogue_id": 2, "line_index": 1, "speaker": "A", "hanzi": "你是哪国人？", "pinyin": "nǐ shì nǎ guó rén?", "arabic": "ما جنسيتك؟", "type": "dialogue" },
  { "id": 1022, "lesson": 4, "dialogue_id": 2, "line_index": 2, "speaker": "B", "hanzi": "我是美国人。你呢？", "pinyin": "wǒ shì měi guó rén. nǐ ne?", "arabic": "أنا أمريكي. وأنت؟", "type": "dialogue" },
  { "id": 1023, "lesson": 4, "dialogue_id": 2, "line_index": 3, "speaker": "A", "hanzi": "我是中国人。", "pinyin": "wǒ shì zhōng guó rén.", "arabic": "أنا صيني.", "type": "dialogue" },
  { "id": 1024, "lesson": 4, "dialogue_id": 3, "line_index": 1, "speaker": "A", "hanzi": "他是谁？", "pinyin": "tā shì shéi?", "arabic": "من هو؟", "type": "dialogue" },
  { "id": 1025, "lesson": 4, "dialogue_id": 3, "line_index": 2, "speaker": "B", "hanzi": "他是我同学。", "pinyin": "tā shì wǒ tóng xué.", "arabic": "هو زميلي.", "type": "dialogue" },
  { "id": 1026, "lesson": 4, "dialogue_id": 3, "line_index": 3, "speaker": "A", "hanzi": "她呢？她是你同学吗？", "pinyin": "tā ne? tā shì nǐ tóng xué ma?", "arabic": "وهي؟ هل هي زميلتك؟", "type": "dialogue" },
  { "id": 1027, "lesson": 4, "dialogue_id": 3, "line_index": 4, "speaker": "B", "hanzi": "她不是我同学，她是我朋友。", "pinyin": "tā bú shì wǒ tóng xué, tā shì wǒ péng you.", "arabic": "إنها ليست زميلتي، إنها صديقتي.", "type": "dialogue" },
  { "id": 1028, "lesson": 5, "dialogue_id": 1, "line_index": 1, "speaker": "A", "hanzi": "你家有几口人？", "pinyin": "nǐ jiā yǒu jǐ kǒu rén?", "arabic": "كم فرداً في أسرتك؟", "type": "dialogue" },
  { "id": 1029, "lesson": 5, "dialogue_id": 1, "line_index": 2, "speaker": "B", "hanzi": "我家有三口人。", "pinyin": "wǒ jiā yǒu sān kǒu rén.", "arabic": "أسرتي بها ثلاثة أفراد.", "type": "dialogue" },
  { "id": 1030, "lesson": 5, "dialogue_id": 2, "line_index": 1, "speaker": "A", "hanzi": "你女儿几岁了？", "pinyin": "nǐ nǚ ér jǐ suì le?", "arabic": "كم عمر ابنتك؟", "type": "dialogue" },
  { "id": 1031, "lesson": 5, "dialogue_id": 2, "line_index": 2, "speaker": "B", "hanzi": "她今年五岁了。", "pinyin": "tā jīn nián wǔ suì le.", "arabic": "هي هذا العام عمرها خمس سنوات.", "type": "dialogue" },
  { "id": 1032, "lesson": 5, "dialogue_id": 3, "line_index": 1, "speaker": "A", "hanzi": "你今年多大？", "pinyin": "nǐ jīn nián duō dà?", "arabic": "كم عمرك هذا العام؟", "type": "dialogue" },
  { "id": 1033, "lesson": 5, "dialogue_id": 3, "line_index": 2, "speaker": "B", "hanzi": "我今年二十岁。", "pinyin": "wǒ jīn nián èr shí suì.", "arabic": "عمري هذا العام عشرون سنة.", "type": "dialogue" },
  { "id": 1034, "lesson": 6, "dialogue_id": 1, "line_index": 1, "speaker": "A", "hanzi": "你会说汉语吗？", "pinyin": "nǐ huì shuō hàn yǔ ma?", "arabic": "هل تستطيع التحدث بالصينية؟", "type": "dialogue" },
  { "id": 1035, "lesson": 6, "dialogue_id": 1, "line_index": 2, "speaker": "B", "hanzi": "我会说汉语。", "pinyin": "wǒ huì shuō hàn yǔ.", "arabic": "أستطيع التحدث بالصينية.", "type": "dialogue" },
  { "id": 1036, "lesson": 6, "dialogue_id": 2, "line_index": 1, "speaker": "A", "hanzi": "妈妈会做中国菜吗？", "pinyin": "mā ma huì zuò zhōng guó cài ma?", "arabic": "هل تستطيع أمي طبخ الطعام الصيني؟", "type": "dialogue" },
  { "id": 1037, "lesson": 6, "dialogue_id": 2, "line_index": 2, "speaker": "B", "hanzi": "她会做，而且很好吃。", "pinyin": "tā huì zuò, ér qiě hěn hǎo chī.", "arabic": "تستطيع، وهو لذيذ جداً.", "type": "dialogue" },
  { "id": 1038, "lesson": 6, "dialogue_id": 3, "line_index": 1, "speaker": "A", "hanzi": "你会写汉字吗？", "pinyin": "nǐ huì xiě hàn zì ma?", "arabic": "هل تستطيع كتابة الرموز الصينية؟", "type": "dialogue" },
  { "id": 1039, "lesson": 6, "dialogue_id": 3, "line_index": 2, "speaker": "B", "hanzi": "我会写，但是很难。", "pinyin": "wǒ huì xiě, dàn shì hěn nán.", "arabic": "أستطيع الكتابة، ولكنها صعبة جداً.", "type": "dialogue" },
  { "id": 1040, "lesson": 7, "dialogue_id": 1, "line_index": 1, "speaker": "A", "hanzi": "请问，今天几号？", "pinyin": "qǐng wèn, jīn tiān jǐ hào?", "arabic": "من فضلك، ما هو تاريخ اليوم؟", "type": "dialogue" },
  { "id": 1041, "lesson": 7, "dialogue_id": 1, "line_index": 2, "speaker": "B", "hanzi": "今天9月1号。", "pinyin": "jīn tiān jiǔ yuè yī hào.", "arabic": "اليوم هو 1 سبتمبر.", "type": "dialogue" },
  { "id": 1042, "lesson": 7, "dialogue_id": 1, "line_index": 3, "speaker": "A", "hanzi": "今天星期几？", "pinyin": "jīn tiān xīng qī jǐ?", "arabic": "أي يوم من الأسبوع اليوم؟", "type": "dialogue" },
  { "id": 1043, "lesson": 7, "dialogue_id": 1, "line_index": 4, "speaker": "B", "hanzi": "星期三。", "pinyin": "xīng qī sān.", "arabic": "الأربعاء.", "type": "dialogue" },
  { "id": 1044, "lesson": 7, "dialogue_id": 2, "line_index": 1, "speaker": "A", "hanzi": "昨天是几月几号？", "pinyin": "zuó tiān shì jǐ yuè jǐ hào?", "arabic": "ما هو تاريخ الأمس؟", "type": "dialogue" },
  { "id": 1045, "lesson": 7, "dialogue_id": 2, "line_index": 2, "speaker": "B", "hanzi": "昨天是8月31号，星期二。", "pinyin": "zuó tiān shì bā yuè sān shí yī hào, xīng qī èr.", "arabic": "الأمس كان 31 أغسطس، الثلاثاء.", "type": "dialogue" },
  { "id": 1046, "lesson": 7, "dialogue_id": 2, "line_index": 3, "speaker": "A", "hanzi": "明天呢？", "pinyin": "míng tiān ne?", "arabic": "وغداً؟", "type": "dialogue" },
  { "id": 1047, "lesson": 7, "dialogue_id": 2, "line_index": 4, "speaker": "B", "hanzi": "明天是9月2号，星期四。", "pinyin": "míng tiān shì jiǔ yuè èr hào, xīng qī sì.", "arabic": "غداً هو 2 سبتمبر، الخميس.", "type": "dialogue" },
  { "id": 1048, "lesson": 7, "dialogue_id": 3, "line_index": 1, "speaker": "A", "hanzi": "明天星期六，你去学校吗？", "pinyin": "míng tiān xīng qī liù, nǐ qù xué xiào ma?", "arabic": "غداً السبت، هل تذهب إلى المدرسة؟", "type": "dialogue" },
  { "id": 1049, "lesson": 7, "dialogue_id": 3, "line_index": 2, "speaker": "B", "hanzi": "我去学校。", "pinyin": "wǒ qù xué xiào.", "arabic": "أذهب إلى المدرسة.", "type": "dialogue" },
  { "id": 1050, "lesson": 7, "dialogue_id": 3, "line_index": 3, "speaker": "A", "hanzi": "你去学校做什么？", "pinyin": "nǐ qù xué xiào zuò shén me?", "arabic": "ماذا تفعل في المدرسة؟", "type": "dialogue" },
  { "id": 1051, "lesson": 7, "dialogue_id": 3, "line_index": 4, "speaker": "B", "hanzi": "我去学校看书。", "pinyin": "wǒ qù xué xiào kàn shū.", "arabic": "أذهب إلى المدرسة لأقرأ الكتب.", "type": "dialogue" },
  { "id": 1052, "lesson": 8, "dialogue_id": 1, "line_index": 1, "speaker": "A", "hanzi": "你想喝什么？", "pinyin": "nǐ xiǎng hē shén me?", "arabic": "ماذا تريد أن تشرب؟", "type": "dialogue" },
  { "id": 1053, "lesson": 8, "dialogue_id": 1, "line_index": 2, "speaker": "B", "hanzi": "我想喝茶。", "pinyin": "wǒ xiǎng hē chá.", "arabic": "أريد شرب الشاي.", "type": "dialogue" },
  { "id": 1054, "lesson": 8, "dialogue_id": 1, "line_index": 3, "speaker": "A", "hanzi": "你想吃什么？", "pinyin": "nǐ xiǎng chī shén me?", "arabic": "ماذا تريد أن تأكل؟", "type": "dialogue" },
  { "id": 1055, "lesson": 8, "dialogue_id": 1, "line_index": 4, "speaker": "B", "hanzi": "我想吃米饭。", "pinyin": "wǒ xiǎng chī mǐ fàn.", "arabic": "أريد أكل الأرز.", "type": "dialogue" },
  { "id": 1056, "lesson": 8, "dialogue_id": 2, "line_index": 1, "speaker": "A", "hanzi": "下午你想做什么？", "pinyin": "xià wǔ nǐ xiǎng zuò shén me?", "arabic": "ماذا تريد أن تفعل بعد الظهر؟", "type": "dialogue" },
  { "id": 1057, "lesson": 8, "dialogue_id": 2, "line_index": 2, "speaker": "B", "hanzi": "下午我想去商店。", "pinyin": "xià wǔ wǒ xiǎng qù shāng diàn.", "arabic": "بعد الظهر أريد الذهاب إلى المتجر.", "type": "dialogue" },
  { "id": 1058, "lesson": 8, "dialogue_id": 2, "line_index": 3, "speaker": "A", "hanzi": "你想买什么？", "pinyin": "nǐ xiǎng mǎi shén me?", "arabic": "ماذا تريد أن تشتري؟", "type": "dialogue" },
  { "id": 1059, "lesson": 8, "dialogue_id": 2, "line_index": 4, "speaker": "B", "hanzi": "我想买一个杯子。", "pinyin": "wǒ xiǎng mǎi yī gè bēi zi.", "arabic": "أريد شراء كوب.", "type": "dialogue" },
  { "id": 1060, "lesson": 8, "dialogue_id": 3, "line_index": 1, "speaker": "A", "hanzi": "你好！这个杯子多少钱？", "pinyin": "nǐ hǎo! zhè gè bēi zi duō shǎo qián?", "arabic": "مرحباً! كم سعر هذا الكوب؟", "type": "dialogue" },
  { "id": 1061, "lesson": 8, "dialogue_id": 3, "line_index": 2, "speaker": "B", "hanzi": "28块。", "pinyin": "èr shí bā kuài.", "arabic": "28 يوان.", "type": "dialogue" },
  { "id": 1062, "lesson": 8, "dialogue_id": 3, "line_index": 3, "speaker": "A", "hanzi": "那个杯子多少钱？", "pinyin": "nà gè bēi zi duō shǎo qián?", "arabic": "كم سعر ذلك الكوب؟", "type": "dialogue" },
  { "id": 1063, "lesson": 8, "dialogue_id": 3, "line_index": 4, "speaker": "B", "hanzi": "那个杯子18块钱。", "pinyin": "nà gè bēi zi shí bā kuài qián.", "arabic": "ذلك الكوب 18 يوان.", "type": "dialogue" },
  { "id": 1064, "lesson": 9, "dialogue_id": 1, "line_index": 1, "speaker": "A", "hanzi": "小猫在哪儿？", "pinyin": "xiǎo māo zài nǎr?", "arabic": "أين القطة الصغيرة؟", "type": "dialogue" },
  { "id": 1065, "lesson": 9, "dialogue_id": 1, "line_index": 2, "speaker": "B", "hanzi": "小猫在那儿。", "pinyin": "xiǎo māo zài nàr.", "arabic": "القطة الصغيرة هناك.", "type": "dialogue" },
  { "id": 1066, "lesson": 9, "dialogue_id": 1, "line_index": 3, "speaker": "A", "hanzi": "小狗在哪儿？", "pinyin": "xiǎo gǒu zài nǎr?", "arabic": "أين الكلب الصغير؟", "type": "dialogue" },
  { "id": 1067, "lesson": 9, "dialogue_id": 1, "line_index": 4, "speaker": "B", "hanzi": "小狗在椅子下面。", "pinyin": "xiǎo gǒu zài yǐ zi xià miàn.", "arabic": "الكلب الصغير تحت الكرسي.", "type": "dialogue" },
  { "id": 1068, "lesson": 9, "dialogue_id": 2, "line_index": 1, "speaker": "A", "hanzi": "你在哪儿工作？", "pinyin": "nǐ zài nǎr gōng zuò?", "arabic": "أين تعمل؟", "type": "dialogue" },
  { "id": 1069, "lesson": 9, "dialogue_id": 2, "line_index": 2, "speaker": "B", "hanzi": "我在学校工作。", "pinyin": "wǒ zài xué xiào gōng zuò.", "arabic": "أعمل في المدرسة.", "type": "dialogue" },
  { "id": 1070, "lesson": 9, "dialogue_id": 2, "line_index": 3, "speaker": "A", "hanzi": "你儿子在哪儿工作？", "pinyin": "nǐ ér zi zài nǎr gōng zuò?", "arabic": "أين يعمل ابنك؟", "type": "dialogue" },
  { "id": 1071, "lesson": 9, "dialogue_id": 2, "line_index": 4, "speaker": "B", "hanzi": "我儿子在医院工作，他是医生。", "pinyin": "wǒ ér zi zài yī yuàn gōng zuò, tā shì yī shēng.", "arabic": "ابني يعمل في المستشفى، هو طبيب.", "type": "dialogue" },
  { "id": 1072, "lesson": 9, "dialogue_id": 3, "line_index": 1, "speaker": "A", "hanzi": "你爸爸在家吗？", "pinyin": "nǐ bà ba zài jiā ma?", "arabic": "هل والدك في المنزل؟", "type": "dialogue" },
  { "id": 1073, "lesson": 9, "dialogue_id": 3, "line_index": 2, "speaker": "B", "hanzi": "不在家。", "pinyin": "bú zài jiā.", "arabic": "ليس في المنزل.", "type": "dialogue" },
  { "id": 1074, "lesson": 9, "dialogue_id": 3, "line_index": 3, "speaker": "A", "hanzi": "他在哪儿呢？", "pinyin": "tā zài nǎr ne?", "arabic": "أين هو إذن؟", "type": "dialogue" },
  { "id": 1075, "lesson": 9, "dialogue_id": 3, "line_index": 4, "speaker": "B", "hanzi": "他在医院。", "pinyin": "tā zài yī yuàn.", "arabic": "هو في المستشفى.", "type": "dialogue" },
  { "id": 1076, "lesson": 10, "dialogue_id": 1, "line_index": 1, "speaker": "A", "hanzi": "桌子上有什么？", "pinyin": "zhuō zi shàng yǒu shén me?", "arabic": "ماذا يوجد على الطاولة؟", "type": "dialogue" },
  { "id": 1077, "lesson": 10, "dialogue_id": 1, "line_index": 2, "speaker": "B", "hanzi": "桌子上有一个电脑和一本书。", "pinyin": "zhuō zi shàng yǒu yī gè diàn nǎo hé yī běn shū.", "arabic": "على الطاولة حاسوب وكتاب.", "type": "dialogue" },
  { "id": 1078, "lesson": 10, "dialogue_id": 1, "line_index": 3, "speaker": "A", "hanzi": "杯子在哪儿？", "pinyin": "bēi zi zài nǎr?", "arabic": "أين الكوب؟", "type": "dialogue" },
  { "id": 1079, "lesson": 10, "dialogue_id": 1, "line_index": 4, "speaker": "B", "hanzi": "杯子在桌子里。", "pinyin": "bēi zi zài zhuō zi lǐ.", "arabic": "الكوب داخل الطاولة.", "type": "dialogue" },
  { "id": 1080, "lesson": 10, "dialogue_id": 2, "line_index": 1, "speaker": "A", "hanzi": "前面那个人叫什么名字？", "pinyin": "qián miàn nà gè rén jiào shén me míng zi?", "arabic": "ما اسم ذلك الشخص الذي في الأمام؟", "type": "dialogue" },
  { "id": 1081, "lesson": 10, "dialogue_id": 2, "line_index": 2, "speaker": "B", "hanzi": "她叫王方，在医院工作。", "pinyin": "tā jiào wáng fāng, zài yī yuàn gōng zuò.", "arabic": "اسمها وانغ فانغ، تعمل في المستشفى.", "type": "dialogue" },
  { "id": 1082, "lesson": 10, "dialogue_id": 2, "line_index": 3, "speaker": "A", "hanzi": "后面那个人呢？他叫什么名字？", "pinyin": "hòu miàn nà gè rén ne? tā jiào shén me míng zi?", "arabic": "ماذا عن ذلك الشخص في الخلف؟ ما اسمه؟", "type": "dialogue" },
  { "id": 1083, "lesson": 10, "dialogue_id": 2, "line_index": 4, "speaker": "B", "hanzi": "他叫谢朋，在商店工作。", "pinyin": "tā jiào xiè péng, zài shāng diàn gōng zuò.", "arabic": "اسمه شيه بينغ، يعمل في المتجر.", "type": "dialogue" },
  { "id": 1084, "lesson": 10, "dialogue_id": 3, "line_index": 1, "speaker": "A", "hanzi": "这儿有人吗？", "pinyin": "zhèr yǒu rén ma?", "arabic": "هل يوجد أحد هنا؟", "type": "dialogue" },
  { "id": 1085, "lesson": 10, "dialogue_id": 3, "line_index": 2, "speaker": "B", "hanzi": "没有。", "pinyin": "méi yǒu.", "arabic": "لا يوجد.", "type": "dialogue" },
  { "id": 1086, "lesson": 10, "dialogue_id": 3, "line_index": 3, "speaker": "A", "hanzi": "我能坐这儿吗？", "pinyin": "wǒ néng zuò zhèr ma?", "arabic": "هل أستطيع الجلوس هنا؟", "type": "dialogue" },
  { "id": 1087, "lesson": 10, "dialogue_id": 3, "line_index": 4, "speaker": "B", "hanzi": "请坐。", "pinyin": "qǐng zuò.", "arabic": "تفضل بالجلوس.", "type": "dialogue" },
  { "id": 1088, "lesson": 11, "dialogue_id": 1, "line_index": 1, "speaker": "A", "hanzi": "现在几点？", "pinyin": "xiàn zài jǐ diǎn?", "arabic": "كم الساعة الآن؟", "type": "dialogue" },
  { "id": 1089, "lesson": 11, "dialogue_id": 1, "line_index": 2, "speaker": "B", "hanzi": "现在十点十分。", "pinyin": "xiàn zài shí diǎn shí fēn.", "arabic": "الآن الساعة العاشرة وعشر دقائق.", "type": "dialogue" },
  { "id": 1090, "lesson": 11, "dialogue_id": 1, "line_index": 3, "speaker": "A", "hanzi": "中午几点吃饭？", "pinyin": "zhōng wǔ jǐ diǎn chī fàn?", "arabic": "متى نأكل عند الظهر؟", "type": "dialogue" },
  { "id": 1091, "lesson": 11, "dialogue_id": 1, "line_index": 4, "speaker": "B", "hanzi": "十二点吃饭。", "pinyin": "shí èr diǎn chī fàn.", "arabic": "نأكل الساعة الثانية عشرة.", "type": "dialogue" },
  { "id": 1092, "lesson": 11, "dialogue_id": 2, "line_index": 1, "speaker": "A", "hanzi": "爸爸什么时候回家？", "pinyin": "bà ba shén me shí hou huí jiā?", "arabic": "متى يعود أبي إلى المنزل؟", "type": "dialogue" },
  { "id": 1093, "lesson": 11, "dialogue_id": 2, "line_index": 2, "speaker": "B", "hanzi": "下午五点。", "pinyin": "xià wǔ wǔ diǎn.", "arabic": "الساعة الخامسة بعد الظهر.", "type": "dialogue" },
  { "id": 1094, "lesson": 11, "dialogue_id": 2, "line_index": 3, "speaker": "A", "hanzi": "我们什么时候去看电影？", "pinyin": "wǒ men shén me shí hou qù kàn diàn yǐng?", "arabic": "متى نذهب لمشاهدة الفيلم؟", "type": "dialogue" },
  { "id": 1095, "lesson": 11, "dialogue_id": 2, "line_index": 4, "speaker": "B", "hanzi": "六点三十分。", "pinyin": "liù diǎn sān shí fēn.", "arabic": "الساعة السادسة والنصف.", "type": "dialogue" },
  { "id": 1096, "lesson": 11, "dialogue_id": 3, "line_index": 1, "speaker": "A", "hanzi": "我星期一去北京。", "pinyin": "wǒ xīng qī yī qù běi jīng.", "arabic": "سأذهب إلى بكين يوم الاثنين.", "type": "dialogue" },
  { "id": 1097, "lesson": 11, "dialogue_id": 3, "line_index": 2, "speaker": "B", "hanzi": "你想在北京住几天？", "pinyin": "nǐ xiǎng zài běi jīng zhù jǐ tiān?", "arabic": "كم يوماً تريد أن تقيم في بكين؟", "type": "dialogue" },
  { "id": 1098, "lesson": 11, "dialogue_id": 3, "line_index": 3, "speaker": "A", "hanzi": "住三天。", "pinyin": "zhù sān tiān.", "arabic": "أقيم ثلاثة أيام.", "type": "dialogue" },
  { "id": 1099, "lesson": 11, "dialogue_id": 3, "line_index": 4, "speaker": "B", "hanzi": "星期五前能回家吗？", "pinyin": "xīng qī wǔ qián néng huí jiā ma?", "arabic": "هل تستطيع العودة إلى المنزل قبل الجمعة؟", "type": "dialogue" },
  { "id": 1100, "lesson": 11, "dialogue_id": 3, "line_index": 5, "speaker": "A", "hanzi": "能。", "pinyin": "néng.", "arabic": "أستطيع.", "type": "dialogue" },
  { "id": 1101, "lesson": 12, "dialogue_id": 1, "line_index": 1, "speaker": "A", "hanzi": "昨天北京的天气怎么样？", "pinyin": "zuó tiān běi jīng de tiān qì zěn me yàng?", "arabic": "كيف كان طقس بكين بالأمس؟", "type": "dialogue" },
  { "id": 1102, "lesson": 12, "dialogue_id": 1, "line_index": 2, "speaker": "B", "hanzi": "太热了。", "pinyin": "tài rè le.", "arabic": "حاراً جداً.", "type": "dialogue" },
  { "id": 1103, "lesson": 12, "dialogue_id": 1, "line_index": 3, "speaker": "A", "hanzi": "明天呢？明天天气怎么样？", "pinyin": "míng tiān ne? míng tiān tiān qì zěn me yàng?", "arabic": "وغداً؟ كيف سيكون الطقس غداً؟", "type": "dialogue" },
  { "id": 1104, "lesson": 12, "dialogue_id": 1, "line_index": 4, "speaker": "B", "hanzi": "明天天气很好，不冷不热。", "pinyin": "míng tiān tiān qì hěn hǎo, bù lěng bú rè.", "arabic": "طقس الغد جيد جداً، لا بارد ولا حار.", "type": "dialogue" },
  { "id": 1105, "lesson": 12, "dialogue_id": 2, "line_index": 1, "speaker": "A", "hanzi": "今天会下雨吗？", "pinyin": "jīn tiān huì xià yǔ ma?", "arabic": "هل ستمطر اليوم؟", "type": "dialogue" },
  { "id": 1106, "lesson": 12, "dialogue_id": 2, "line_index": 2, "speaker": "B", "hanzi": "今天不会下雨。", "pinyin": "jīn tiān bú huì xià yǔ.", "arabic": "لن تمطر اليوم.", "type": "dialogue" },
  { "id": 1107, "lesson": 12, "dialogue_id": 2, "line_index": 3, "speaker": "A", "hanzi": "王小姐今天会来吗？", "pinyin": "wáng xiǎo jiě jīn tiān huì lái ma?", "arabic": "هل ستأتي الآنسة وانغ اليوم؟", "type": "dialogue" },
  { "id": 1108, "lesson": 12, "dialogue_id": 2, "line_index": 4, "speaker": "B", "hanzi": "不会来，天气太冷了。", "pinyin": "bú huì lái, tiān qì tài lěng le.", "arabic": "لن تأتي، الطقس بارد جداً.", "type": "dialogue" },
  { "id": 1109, "lesson": 12, "dialogue_id": 3, "line_index": 1, "speaker": "A", "hanzi": "你身体怎么样？", "pinyin": "nǐ shēn tǐ zěn me yàng?", "arabic": "كيف صحتك؟", "type": "dialogue" },
  { "id": 1110, "lesson": 12, "dialogue_id": 3, "line_index": 2, "speaker": "B", "hanzi": "我身体不太好。天气太热了，不爱吃饭。", "pinyin": "wǒ shēn tǐ bú tài hǎo. tiān qì tài rè le, bú ài chī fàn.", "arabic": "صحتي ليست جيدة جداً. الطقس حار جداً، لا أحب الأكل.", "type": "dialogue" },
  { "id": 1111, "lesson": 12, "dialogue_id": 3, "line_index": 3, "speaker": "A", "hanzi": "你多吃些水果，多喝水。", "pinyin": "nǐ duō chī xiē shuǐ guǒ, duō hē shuǐ.", "arabic": "تناول المزيد من الفاكهة، واشرب المزيد من الماء.", "type": "dialogue" },
  { "id": 1112, "lesson": 12, "dialogue_id": 3, "line_index": 4, "speaker": "B", "hanzi": "谢谢你，医生。", "pinyin": "xiè xie nǐ, yī shēng.", "arabic": "شكراً لك، أيها الطبيب.", "type": "dialogue" },
  { "id": 1113, "lesson": 13, "dialogue_id": 1, "line_index": 1, "speaker": "A", "hanzi": "喂，你在做什么呢？", "pinyin": "wèi, nǐ zài zuò shén me ne?", "arabic": "ألو، ماذا تفعل؟", "type": "dialogue" },
  { "id": 1114, "lesson": 13, "dialogue_id": 1, "line_index": 2, "speaker": "B", "hanzi": "我在看书呢。", "pinyin": "wǒ zài kàn shū ne.", "arabic": "أنا أقرأ كتاباً.", "type": "dialogue" },
  { "id": 1115, "lesson": 13, "dialogue_id": 1, "line_index": 3, "speaker": "A", "hanzi": "大卫也在看书吗？", "pinyin": "dà wèi yě zài kàn shū ma?", "arabic": "هل ديفيد يقرأ كتاباً أيضاً؟", "type": "dialogue" },
  { "id": 1116, "lesson": 13, "dialogue_id": 1, "line_index": 4, "speaker": "B", "hanzi": "他没看书，他在学做中国菜呢。", "pinyin": "tā méi kàn shū, tā zài xué zuò zhōng guó cài ne.", "arabic": "هو لا يقرأ، هو يتعلم طبخ الطعام الصيني.", "type": "dialogue" },
  { "id": 1117, "lesson": 13, "dialogue_id": 2, "line_index": 1, "speaker": "A", "hanzi": "昨天上午你在做什么呢？", "pinyin": "zuó tiān shàng wǔ nǐ zài zuò shén me ne?", "arabic": "ماذا كنت تفعل صباح الأمس؟", "type": "dialogue" },
  { "id": 1118, "lesson": 13, "dialogue_id": 2, "line_index": 2, "speaker": "B", "hanzi": "我在睡觉呢。你呢？", "pinyin": "wǒ zài shuì jiào ne. nǐ ne?", "arabic": "كنت نائماً. وأنت؟", "type": "dialogue" },
  { "id": 1119, "lesson": 13, "dialogue_id": 2, "line_index": 3, "speaker": "A", "hanzi": "我在家看电视呢。你喜欢看电视吗？", "pinyin": "wǒ zài jiā kàn diàn shì ne. nǐ xǐ huān kàn diàn shì ma?", "arabic": "كنت أشاهد التلفاز في البيت. هل تحب مشاهدة التلفاز؟", "type": "dialogue" },
  { "id": 1120, "lesson": 13, "dialogue_id": 2, "line_index": 4, "speaker": "B", "hanzi": "我不喜欢看电视，我喜欢看电影。", "pinyin": "wǒ bù xǐ huān kàn diàn shì, wǒ xǐ huān kàn diàn yǐng.", "arabic": "لا أحب مشاهدة التلفاز، أحب مشاهدة الأفلام.", "type": "dialogue" },
  { "id": 1121, "lesson": 13, "dialogue_id": 3, "line_index": 1, "speaker": "A", "hanzi": "82304155 这是李老师的电话吗？", "pinyin": "bā èr sān líng sì yāo wǔ wǔ, zhè shì lǐ lǎo shī de diàn huà ma?", "arabic": "82304155 هل هذا هاتف المعلمة لي؟", "type": "dialogue" },
  { "id": 1122, "lesson": 13, "dialogue_id": 3, "line_index": 2, "speaker": "B", "hanzi": "不是。她的电话是82304156。", "pinyin": "bú shì. tā de diàn huà shì bā èr sān líng sì yāo wǔ liù.", "arabic": "لا. هاتفها هو 82304156.", "type": "dialogue" },
  { "id": 1123, "lesson": 13, "dialogue_id": 3, "line_index": 3, "speaker": "A", "hanzi": "好，我现在给她打电话。", "pinyin": "hǎo, wǒ xiàn zài gěi tā dǎ diàn huà.", "arabic": "حسناً، سأتصل بها الآن.", "type": "dialogue" },
  { "id": 1124, "lesson": 13, "dialogue_id": 3, "line_index": 4, "speaker": "B", "hanzi": "她在工作呢，你下午打吧。", "pinyin": "tā zài gōng zuò ne, nǐ xià wǔ dǎ ba.", "arabic": "إنها تعمل الآن، اتصل بعد الظهر.", "type": "dialogue" },
  { "id": 1125, "lesson": 14, "dialogue_id": 1, "line_index": 1, "speaker": "A", "hanzi": "昨天上午你去哪儿了？", "pinyin": "zuó tiān shàng wǔ nǐ qù nǎr le?", "arabic": "أين ذهبت صباح الأمس؟", "type": "dialogue" },
  { "id": 1126, "lesson": 14, "dialogue_id": 1, "line_index": 2, "speaker": "B", "hanzi": "我去商店买东西了。", "pinyin": "wǒ qù shāng diàn mǎi dōng xī le.", "arabic": "ذهبت إلى المتجر لشراء الأشياء.", "type": "dialogue" },
  { "id": 1127, "lesson": 14, "dialogue_id": 1, "line_index": 3, "speaker": "A", "hanzi": "你买什么了？", "pinyin": "nǐ mǎi shén me le?", "arabic": "ماذا اشتريت؟", "type": "dialogue" },
  { "id": 1128, "lesson": 14, "dialogue_id": 1, "line_index": 4, "speaker": "B", "hanzi": "我买了一点儿苹果。", "pinyin": "wǒ mǎi le yī diǎnr píng guǒ.", "arabic": "اشتريت قليلاً من التفاح.", "type": "dialogue" },
  { "id": 1129, "lesson": 14, "dialogue_id": 2, "line_index": 1, "speaker": "A", "hanzi": "你看见张先生了吗？", "pinyin": "nǐ kàn jiàn zhāng xiān sheng le ma?", "arabic": "هل رأيت السيد تشانغ؟", "type": "dialogue" },
  { "id": 1130, "lesson": 14, "dialogue_id": 2, "line_index": 2, "speaker": "B", "hanzi": "看见了，他去学开车了。", "pinyin": "kàn jiàn le, tā qù xué kāi chē le.", "arabic": "رأيته، ذهب ليتعلم قيادة السيارة.", "type": "dialogue" },
  { "id": 1131, "lesson": 14, "dialogue_id": 2, "line_index": 3, "speaker": "A", "hanzi": "他什么时候能回来？", "pinyin": "tā shén me shí hou néng huí lái?", "arabic": "متى يستطيع العودة؟", "type": "dialogue" },
  { "id": 1132, "lesson": 14, "dialogue_id": 2, "line_index": 4, "speaker": "B", "hanzi": "40分钟后回来。", "pinyin": "sì shí fēn zhōng hòu huí lái.", "arabic": "يعود بعد 40 دقيقة.", "type": "dialogue" },
  { "id": 1133, "lesson": 14, "dialogue_id": 3, "line_index": 1, "speaker": "A", "hanzi": "王方的衣服太漂亮了！", "pinyin": "wáng fāng de yī fu tài piào liang le!", "arabic": "ملابس وانغ فانغ جميلة جداً!", "type": "dialogue" },
  { "id": 1134, "lesson": 14, "dialogue_id": 3, "line_index": 2, "speaker": "B", "hanzi": "是啊，她买了不少衣服。", "pinyin": "shì a, tā mǎi le bù shǎo yī fu.", "arabic": "نعم، لقد اشترت الكثير من الملابس.", "type": "dialogue" },
  { "id": 1135, "lesson": 14, "dialogue_id": 3, "line_index": 3, "speaker": "A", "hanzi": "你买什么了？", "pinyin": "nǐ mǎi shén me le?", "arabic": "ماذا اشتريت أنت؟", "type": "dialogue" },
  { "id": 1136, "lesson": 14, "dialogue_id": 3, "line_index": 4, "speaker": "B", "hanzi": "我没买，这些都是王方的东西。", "pinyin": "wǒ méi mǎi, zhè xiē dōu shì wáng fāng de dōng xī.", "arabic": "لم أشترِ، كل هذه أغراض وانغ فانغ.", "type": "dialogue" },
  { "id": 1137, "lesson": 15, "dialogue_id": 1, "line_index": 1, "speaker": "A", "hanzi": "你和李小姐是什么时候认识的？", "pinyin": "nǐ hé lǐ xiǎo jiě shì shén me shí hou rèn shi de?", "arabic": "متى تعرفت أنت والآنسة لي؟", "type": "dialogue" },
  { "id": 1138, "lesson": 15, "dialogue_id": 1, "line_index": 2, "speaker": "B", "hanzi": "我们是2011年9月认识的。", "pinyin": "wǒ men shì èr líng yī yī nián jiǔ yuè rèn shi de.", "arabic": "تعارفنا في سبتمبر عام 2011.", "type": "dialogue" },
  { "id": 1139, "lesson": 15, "dialogue_id": 1, "line_index": 3, "speaker": "A", "hanzi": "你们在哪儿认识的？", "pinyin": "nǐ men zài nǎr rèn shi de?", "arabic": "أين تعرفتما؟", "type": "dialogue" },
  { "id": 1140, "lesson": 15, "dialogue_id": 1, "line_index": 4, "speaker": "B", "hanzi": "我们是在学校认识的，她是我大学同学。", "pinyin": "wǒ men shì zài xué xiào rèn shi de, tā shì wǒ dà xué tóng xué.", "arabic": "تعارفنا في المدرسة، كانت زميلتي في الجامعة.", "type": "dialogue" },
  { "id": 1141, "lesson": 15, "dialogue_id": 2, "line_index": 1, "speaker": "A", "hanzi": "你们是怎么来饭店的？", "pinyin": "nǐ men shì zěn me lái fàn diàn de?", "arabic": "كيف جئتم إلى المطعم؟", "type": "dialogue" },
  { "id": 1142, "lesson": 15, "dialogue_id": 2, "line_index": 2, "speaker": "B", "hanzi": "我们是坐出租车来的。", "pinyin": "wǒ men shì zuò chū zū chē lái de.", "arabic": "جئنا بسيارة الأجرة.", "type": "dialogue" },
  { "id": 1143, "lesson": 15, "dialogue_id": 2, "line_index": 3, "speaker": "A", "hanzi": "李先生呢？", "pinyin": "lǐ xiān sheng ne?", "arabic": "ماذا عن السيد لي؟", "type": "dialogue" },
  { "id": 1144, "lesson": 15, "dialogue_id": 2, "line_index": 4, "speaker": "B", "hanzi": "他是和朋友一起开车来的。", "pinyin": "tā shì hé péng you yī qǐ kāi chē lái de.", "arabic": "جاء بالسيارة مع صديق.", "type": "dialogue" },
  { "id": 1145, "lesson": 15, "dialogue_id": 3, "line_index": 1, "speaker": "A", "hanzi": "很高兴认识您！李小姐。", "pinyin": "hěn gāo xìng rèn shi nín! lǐ xiǎo jiě.", "arabic": "سعيد جداً بالتعرف عليكِ، آنسة لي.", "type": "dialogue" },
  { "id": 1146, "lesson": 15, "dialogue_id": 3, "line_index": 2, "speaker": "B", "hanzi": "认识你我也很高兴！", "pinyin": "rèn shi nǐ wǒ yě hěn gāo xìng!", "arabic": "أنا أيضاً سعيدة بالتعرف عليك.", "type": "dialogue" },
